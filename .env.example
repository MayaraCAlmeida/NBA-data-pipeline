# Configurações do banco de dados PostgreSQL
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no GitHub

DB_HOST=localhost        # host do banco (localhost ou endereço em nuvem)
DB_PORT=5432             # porta padrão do PostgreSQL
DB_NAME=nba_pipeline     # nome do banco de dados
DB_USER=postgres         # usuário do banco
DB_PASSWORD=sua_senha    # senha do banco